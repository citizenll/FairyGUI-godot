@tool
class_name FGUIBindingCodeGenerator
extends RefCounted

const GENERATED_MARKER := "# Generated by FairyGUI Godot. DO NOT EDIT."
const GENERATOR_VERSION := 9
const DEFAULT_OUTPUT_DIR := "res://generated/fairygui"
const REGISTRY_FILE := "registry.gd"
const MANIFEST_FILE := "manifest.json"

const TYPE_NAMES := {
