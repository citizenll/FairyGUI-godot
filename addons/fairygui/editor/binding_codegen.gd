	FGUIEnums.OBJECT_COMPONENT: "FGUIComponent",
	FGUIEnums.OBJECT_LIST: "FGUIList",
	FGUIEnums.OBJECT_LABEL: "FGUILabel",
	FGUIEnums.OBJECT_BUTTON: "FGUIButton",
	FGUIEnums.OBJECT_COMBO_BOX: "FGUIComboBox",
	FGUIEnums.OBJECT_PROGRESS_BAR: "FGUIProgressBar",
	FGUIEnums.OBJECT_SLIDER: "FGUISlider",
