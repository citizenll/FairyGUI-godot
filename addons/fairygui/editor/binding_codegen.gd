const TYPE_SCRIPT_PATHS := {
	"FGUIObject": "res://addons/fairygui/ui/gobject.gd",
	"FGUIImage": "res://addons/fairygui/ui/gimage.gd",
	"FGUIMovieClip": "res://addons/fairygui/ui/gmovie_clip.gd",
	"FGUIGraph": "res://addons/fairygui/ui/ggraph.gd",
	"FGUILoader": "res://addons/fairygui/ui/gloader.gd",
	"FGUIGroup": "res://addons/fairygui/ui/ggroup.gd",
	"FGUITextField": "res://addons/fairygui/ui/gtext_field.gd",
	"FGUIRichTextField": "res://addons/fairygui/ui/grich_text_field.gd",
	"FGUITextInput": "res://addons/fairygui/ui/gtext_input.gd",
	"FGUIComponent": "res://addons/fairygui/ui/gcomponent.gd",
	"FGUIList": "res://addons/fairygui/ui/glist.gd",
	"FGUILabel": "res://addons/fairygui/ui/glabel.gd",
